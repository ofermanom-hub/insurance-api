# Copy to .env for local development

# "development" enables /docs and /redoc; "production" disables them
ENV=development

# Override upstream if needed (e.g. to point at a mock during testing)
UPSTREAM_URL=https://insurance-webhook-945894769129.us-central1.run.app/vehicle-info

# Comma-separated list of allowed CORS origins
# Use "*" for open access (development) or restrict to your Insait domain in production
ALLOWED_ORIGINS=*
